# JamZia.TV — Network Solutions Compatible .htaccess
# Simplified for shared hosting — no restricted modules

# Enable rewrite engine
RewriteEngine On

# Route /jamvideo to /jamvideo/index.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^jamvideo/?$ jamvideo/index.html [L]

RewriteRule ^jamaudio/?$ jamaudio/index.html [L]
RewriteRule ^jamplay/?$ jamplay/index.html [L]
RewriteRule ^jamlearn/?$ jamlearn/index.html [L]
RewriteRule ^jamsocial/?$ jamsocial/index.html [L]
RewriteRule ^jamads/?$ jamads/index.html [L]
RewriteRule ^jampay/?$ jampay/index.html [L]
RewriteRule ^jamshop/?$ jamshop/index.html [L]
RewriteRule ^jamcloud/?$ jamcloud/index.html [L]

# Custom 404 page
ErrorDocument 404 /index.html
